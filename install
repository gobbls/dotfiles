#!/usr/bin/env bash


#################### META STUFF #################### 

R="\e[m"
BOLD="\e[1m"
ITALIC="\e[3m"
RED="\e[31m"
GREEN="\e[32m"
YELLOW="\e[33m"
BLUE="\e[34m"

OK="[${BOLD}${GREEN}+${R}]"
INFO="[${BOLD}>${R}]"
WARNING="[${BOLD}${YELLOW}-${R}]"
ERROR="[${BOLD}${RED}!${R}]"

logging_info() { echo -e "$INFO $1"; }
logging_ok() { echo -e "$OK $1"; }
logging_warning() { echo -e "$WARNING $1"; }
logging_error() { echo -e "$ERROR $1"; }

separator() { echo "--------------------------------------------------------------------------------"; }

yes_no() {
	local q="${1:-Continue?}"
	read -r -p "$q [y/N]: " answer
	[[ $answer =~ ^[Yy]$ ]]
}

check_create_dir() {
	local path=$1
	if [[ ! -e "$path" ]]; then
		logging_info "Directory [${path}] not found. Creating..."
		if ! mkdir -p -- "$path"; then
			logging_error "Error occurred while creating direcory [${path}]! Cancelling..."
			exit 1
		fi
	fi
}

#################### STARTUP ####################

logging_info "Bootstrapping Gobbls' dots..."

#################### SYSTEM CHECKS ####################

logging_info "Checking if [sudo] is accessible..."
if type -p sudo > /dev/null 2>&1; then
	logging_ok "[sudo] is accessible"
else
	logging_error "[sudo] not available, but is required to install packages! Cancelling..."
	exit 1
fi

dest="archlinux.org"
logging_info "Checking for WAN connection (pinging ${dest})..."
if ping -c 2 -W 3 -q "$dest" > /dev/null 2>&1; then
	logging_ok "Verified connection"
else
	logging_error "${dest} not reachable! Internet connection is required. Cancelling..."
	exit 1
fi

dist="Arch Linux"
logging_info "Checking if system is ${dist}..."
if [[ -f /etc/os-release ]]; then
	source /etc/os-release
else
	logging_error "Unable to locate [/etc/os-release]: Not able to check if distro type is ${dist}. Cancelling..."
	exit 1
fi

if [[ $ID == "arch" ]]; then
    logging_ok "System is ${dist}"
elif [[ $ID_LIKE == *"arch"* ]]; then
    logging_warning "System is *based* on ${dist}, this script is not tested on such systems"
	if ! yes_no "Continue?"; then
		logging_info "Cancelling..."
		exit 0
	fi
else
	logging_error "This installation script is not made for systems other than ${dist}! Cancelling..."
	exit 1
fi

#################### DEPLOY DOTFILES #################### 

backup_conf() {
	local path=$1
	local bak_num=1
	local bak_path="${path}.bak"
	while [[ -e $bak_path ]]; do
		bak_num=$((bak_num + 1))
		bak_path="${path}.bak${bak_num}"
	done
	if ! mv -- "$path" "$bak_path"; then
		logging_error "Error occurred while moving [${path}] to [${bak_path}]! Cancelling..."
		exit 1
	fi
	logging_ok "[${path}] backed up to [${bak_path}]"
}

create_symlink() {
	local source_path=$1
	local target_path=$2
	if ! ln -s -- "$source_path" "$target_path"; then
		logging_error "Error occurred while symlinking [[${target_path}] --> [${source_path}]]! Cancelling..."
		exit 1
	fi
	logging_ok "Symlink created: [[${target_conf_path}] --> [${source_path}]]"
}

deploy_dir() {
	separator
	local conf_source=$1 conf_target=$2 conf_ignore=${3-}
	logging_info "Deploying from [${conf_source}/]..."
	check_create_dir "$conf_target"
	for conf in "$conf_source"/* "$conf_source"/.*; do
		[[ -e $conf ]] || continue # skip the [$conf_source/*] literals if there is no match
		local conf_name=${conf##*/}
		[[ $conf_name == $conf_ignore ]] && continue
		logging_info "Linking [${conf}]..."
		local target_conf_path="${conf_target}/${conf_name}"
		if [[ -e $target_conf_path ]]; then
			logging_warning "[${conf_name}] already exists in [${conf_target}/]! Creating backup before linking..."
			backup_conf "$target_conf_path"
		fi
		create_symlink "$conf" "$target_conf_path"
	done
}

#			source_path									target_path							ignore_item
deploy_dir 	"$(pwd)/dotfiles/.config" 					"${HOME}/.config"
deploy_dir 	"$(pwd)/dotfiles/.local/share/applications"	"${HOME}/.local/share/applications"
deploy_dir 	"$(pwd)/dotfiles" 							"$HOME" 							".config"

#################### PACMAN INSTALL #################### 

logging_info "Installing packages with [pacman]..."
pacman_packages_len=$(wc -l packages/pacman.txt | awk '{print $1}')
logging_info "Synchronizing packages (this might take some time)..."
if ! sudo pacman -Sy > /dev/null 2>&1; then
	logging_error "Error occurred while synching packages! Cancelling..."
	exit 1
fi
logging_info "Installing [${pacman_packages_len}] packages (this might take some time)..."
mapfile -t pacman_packages < packages/pacman.txt
if sudo pacman -S --needed --noconfirm "${pacman_packages[@]}" > /dev/null 2>&1; then
	logging_ok "Successfully installed [pacman] packages"
else
	logging_error "Error occurred while installing [pacman] packages! Cancelling..."
	exit 1
fi

#################### RUSTUP INSTALL ####################

logging_info "Installing [rust] with [rustup]..."
if ! type -p rustup > /dev/null 2>&1; then
	logging_warning "[rustup] should have been installed before, but was not found! Cancelling..."
	exit 1
fi

if rustup default stable > /dev/null 2>&1; then
	logging_ok "[rust] installed successfully"
else
	logging_error "Error occurred while installing [rust]! Cancelling..."
	exit 1
fi

#################### INSTALL PARU ####################

logging_info "Checking if [Paru] is installed..."
paru_git="https://aur.archlinux.org/paru.git"
if ! type -p paru > /dev/null 2>&1; then
	logging_info "[paru] not found. Installing..."
	temp_dir=$(mktemp -d)
	logging_info "Temporary directory [${temp_dir}] created"
	logging_info "Cloning repo..."
	if ! git clone "$paru_git" "$temp_dir" > /dev/null 2>&1; then
		logging_error "Failed to clone the [paru] repo! Cleaning up then cancelling..."
		rmdir "$temp_dir"
		exit 1
	fi
	cd "$temp_dir"
	logging_info "Building package with [makepkg]..."
	if makepkg -si --noconfirm > /dev/null 2>&1; then
		logging_info "Build complete. Cleaning up..."
	else
		logging_error "Error occurred while building Paru! Cancelling..."
		exit 1
	fi
	cd -
	rm -rf "$temp_dir"
else
	logging_info "Paru is already installed. Skipping..."
fi

#################### PARU INSTALL ####################

paru_packages_len=$(wc -l packages/paru.txt | awk '{print $1}')
logging_info "Installing [${paru_packages_len}] packages (this might take some time)..."
mapfile -t paru_packages < packages/paru.txt
if paru -S --needed --noconfirm "${paru_packages[@]}" > /dev/null 2>&1; then
	logging_ok "Successfully installed [paru] packages"
else
	logging_error "Error occurred when installing [paru] packages! Cancelling..."
	exit 1
fi

#################### ENABLE SERVICES ####################

logging_info "Enabling services..."
mapfile -t services < services.txt
if sudo systemctl enable --now "${services[@]}" > /dev/null 2>&1; then
	logging_ok "Services enabled"
else
	logging_warning "Error occurred while enabling service(s)! Cancelling..."
	exit 1
fi

#################### ENABLE VIRSH ####################

#sudo virsh net-start default
#sudo virsh net-autostart default

#################### VSCODE EXTENSIONS INSTALL ####################

logging_info "Installing [code-oss] extensions..."
cat ./configure/code-oss/extensions.txt | xargs -n 1 code --install-extension

#################### ADD USER TO LIBVIRT GROUP ####################

# For permission to start up kvm/qemu.
logging_info "Adding [${$USER}] to [libvirt] group..."
if sudo usermod -aG libvirt $USER; then
	logging_ok "User added to group without issues"
else
	logging_error "Unable to add user to group! Cancelling..."
	exit 1
fi

#################### SYMLINK KEYD CONFIG ####################

logging_info "Symlinking [keyd] config..."
if sudo ln -s $HOME/.config/keyd/default.conf /etc/keyd/; then
	logging_ok "[keyd] config symlinked without isses"
else
	logging_error "Error occurred while symlinking [keyd] config! Cancelling..."
	exit 1
fi
